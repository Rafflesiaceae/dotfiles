#!/usr/bin/env bash
set -eo pipefail

base="$(pwd -P)"

rg --files -0 |
  xargs -0 -P "$(nproc)" -n 200 -- file --mime-type -- |
  awk -F: -v base="$base" '
    $2 ~ /^[[:space:]]*text\// || $2 ~ /application\/x-empty/ {
      p=$1
      sub(/^[[:space:]]+/, "", p)
      if (p ~ /^\//) print p
      else print base "/" p
    }
  '
