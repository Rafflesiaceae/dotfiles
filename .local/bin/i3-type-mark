#!/bin/sh

die() {
    echo "$*" >&2
    exit 1
}

show_help() {
    cat <<'EOF'
usage:

  -h/--help      show this message here
  -ne/--no-enter don't send a <CR> at the end
  -f/--focus     focus at the end
  -k/--key       send a key, e.g.: `ctrl+u` instead of typing
EOF
    exit 255
}

end_with_cr=1
focus=0
keys=""

while :; do
    case ${1-} in
    -h | -\? | --help)
        show_help
        ;;
    -ne | --no-enter)
        end_with_cr=0
        ;;
    -f | --focus)
        focus=1
        ;;
    -k | --key)
        if [ -n "${2-}" ]; then
            keys="$keys $2"
            shift
        else
            die "-k|--key requires a single follow up argument"
        fi
        ;;
    --)
        shift
        break
        ;;
    -?*)
        printf 'WARN: Unknown option (ignored): %s\n' "$1" >&2
        ;;
    *)
        break
        ;;
    esac
    shift
done

mark=${1-}
[ -n "$mark" ] || die "missing mark argument"
shift

window_id=$(i3-msg -t get_tree | jq -r ".. | select(.window?) | select(.marks // [] | contains([\"$mark\"])).window" | head -n1)
[ -n "$window_id" ] || die "can't find mark: $mark"

if [ "$focus" -eq 1 ]; then
    xdotool windowfocus --sync "$window_id"
fi
sleep 0.1

for key in $keys; do
    xdotool key --clearmodifiers --window "$window_id" "$key"
done

if [ "$#" -gt 0 ]; then
    xdotool type --clearmodifiers --window "$window_id" "$*"
    if [ "$end_with_cr" -eq 1 ]; then
        xdotool key --clearmodifiers --window "$window_id" Return
    fi
fi
